{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "left": 42, "right": 28, "top": 2, "bottom": 12 },
  "title": {
    "text": "Smoking Is Highest Among Middle-Aged Adults",
    "subtitle": "Adults aged 35–44 recorded the highest smoking prevalence in 2023.",
    "font": "Georgia",
    "fontSize": 32,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 18,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 15,
    "anchor": "start",
    "offset": 45
  },
  "width": 760,
  "height": 620,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_age.csv"
  },
  "transform": [{ "calculate": "0", "as": "Zero" }],
  "layer": [
    {
      "mark": { "type": "rule", "strokeWidth": 3.2, "opacity": 1 },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "title": null,
          "sort": ["15-24","25-34","35-44","45-54","55-64","65-74","75 and above"],
          "axis": {
            "labelFont": "Arial",
            "labelFontSize": 16,
            "labelColor": "#555555",
            "labelPadding": 12,
            "domain": false,
            "ticks": false
          }
        },
        "x": {
          "field": "Zero",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": { "domain": [0, 30], "nice": false },
          "axis": {
            "values": [0, 5, 10, 15, 20, 25, 30],
            "titleFont": "Arial",
            "titleFontSize": 16,
            "titleFontWeight": 700,
            "titleColor": "#555555",
            "titlePadding": 18,
            "labelFont": "Arial",
            "labelFontSize": 16,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        },
        "x2": { "field": "Smoking_Prevalence" },
        "color": {
          "condition": { "test": "datum.Focus === 'Focus'", "value": "#E75480" },
          "value": "#d0d0d0"
        },
        "tooltip": [
          { "field": "Age_Group", "type": "ordinal", "title": "Age group" },
          { "field": "Smoking_Prevalence", "type": "quantitative", "title": "Smoking prevalence (%)", "format": ".1f" }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 160,
        "stroke": "#ffffff",
        "strokeWidth": 1.5,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": ["15-24","25-34","35-44","45-54","55-64","65-74","75 and above"]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": { "domain": [0, 30], "nice": false }
        },
        "color": {
          "condition": { "test": "datum.Focus === 'Focus'", "value": "#E75480" },
          "value": "#8f8f8f"
        },
        "tooltip": [
          { "field": "Age_Group", "type": "ordinal", "title": "Age group" },
          { "field": "Smoking_Prevalence", "type": "quantitative", "title": "Smoking prevalence (%)", "format": ".1f" }
        ]
      }
    },
    {
      "transform": [{ "filter": "datum.Focus === 'Focus'" }],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 700,
        "color": "#E75480",
        "align": "left",
        "baseline": "middle",
        "dx": 10
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": ["15-24","25-34","35-44","45-54","55-64","65-74","75 and above"]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": { "domain": [0, 30], "nice": false }
        },
        "text": { "field": "Label" }
      }
    },
    {
      "transform": [{ "filter": "datum.Focus !== 'Focus'" }],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "middle",
        "dx": 10
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": ["15-24","25-34","35-44","45-54","55-64","65-74","75 and above"]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": { "domain": [0, 30], "nice": false }
        },
        "text": { "field": "Label" }
      }
    },
    {
      "data": {
        "values": [
          {
            "Age_Group": "35-44",
            "Smoking_Prevalence": 28,
            "Text": "Highest prevalence:\n25.0% among adults\naged 35–44."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 400,
        "color": "#E75480",
        "align": "left",
        "baseline": "middle",
        "lineBreak": "\n",
        "lineHeight": 17,
        "limit": 210
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": ["15-24","25-34","35-44","45-54","55-64","65-74","75 and above"]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": { "domain": [0, 30], "nice": false }
        },
        "text": { "field": "Text" }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": { "stroke": null },
    "legend": { "disable": true }
  }
}