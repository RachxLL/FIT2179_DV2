{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "left": 4, "right": 4, "top": 2, "bottom": 12 },
  "title": {
    "text": "Smoking Is Highest Among Middle-Aged Adults",
    "subtitle": "Adults aged 35–44 recorded the highest smoking prevalence in 2023.",
    "font": "Georgia",
    "fontSize": 40,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 38,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 19,
    "anchor": "start",
    "offset": 45
  },
  "width": 800,
  "height": 800,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_age.csv"
  },
  "transform": [
    {
      "calculate": "0",
      "as": "Zero"
    },
    {
      "calculate": "datum.Age_Group === '75 and above' ? '75+' : datum.Age_Group",
      "as": "Age_Group_Display"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 8,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Age_Group_Display",
          "type": "ordinal",
          "title": null,
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75+"
          ],
          "axis": {
            "labelFont": "Arial",
            "labelFontSize": 35,
            "labelColor": "#555555",
            "labelPadding": 12,
            "domain": false,
            "ticks": false
          }
        },
        "x": {
          "field": "Zero",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [0, 30],
            "nice": false
          },
          "axis": {
            "values": [0, 5, 10, 15, 20, 25, 30],
            "titleFont": "Arial",
            "titleFontSize": 30,
            "titleFontWeight": 700,
            "titleColor": "#555555",
            "titlePadding": 18,
            "labelFont": "Arial",
            "labelFontSize": 35,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        },
        "x2": {
          "field": "Smoking_Prevalence"
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#E75480"
          },
          "value": "#d0d0d0"
        },
        "tooltip": [
          {
            "field": "Age_Group_Display",
            "type": "ordinal",
            "title": "Age group"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 500,
        "stroke": "#ffffff",
        "strokeWidth": 1.5,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Age_Group_Display",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75+"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#E75480"
          },
          "value": "#8f8f8f"
        },
        "tooltip": [
          {
            "field": "Age_Group_Display",
            "type": "ordinal",
            "title": "Age group"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus === 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 40,
        "fontWeight": 700,
        "color": "#E75480",
        "align": "left",
        "baseline": "middle",
        "dx": 10
      },
      "encoding": {
        "y": {
          "field": "Age_Group_Display",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75+"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus !== 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 25,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "middle",
        "dx": 10
      },
      "encoding": {
        "y": {
          "field": "Age_Group_Display",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75+"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Age_Group_Display": "35-44",
            "Smoking_Prevalence": 30,
            "Text": "Highest prevalence:\n25.0% among adults\naged 35–44."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 25,
        "fontWeight": 700,
        "color": "#E75480",
        "align": "left",
        "baseline": "middle",
        "lineBreak": "\n",
        "lineHeight": 40,
        "limit": 1000
      },
      "encoding": {
        "y": {
          "field": "Age_Group_Display",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75+"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Text"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "legend": {
      "disable": true
    }
  }
}