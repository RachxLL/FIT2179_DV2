{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {
    "left": 24,
    "right": 24,
    "top": 10,
    "bottom": 28
  },
  "title": {
    "text": "Smoking Is Highest Among Middle-Aged Adults",
    "subtitle": "Adults aged 35–44 recorded the highest smoking prevalence in 2023.",
    "font": "Georgia",
    "fontSize": 22,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 15,
    "anchor": "start",
    "offset": 45
  },
  "width": 680,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_age.csv"
  },
  "transform": [
    {
      "calculate": "0",
      "as": "Zero"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "title": null,
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75 and above"
          ],
          "axis": {
            "labelFont": "Arial",
            "labelFontSize": 11,
            "labelColor": "#555555",
            "labelPadding": 10,
            "domain": false,
            "ticks": false
          }
        },
        "x": {
          "field": "Zero",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [0, 30],
            "nice": false
          },
          "axis": {
            "values": [0, 5, 10, 15, 20, 25, 30],
            "titleFont": "Arial",
            "titleFontSize": 11,
            "titleFontWeight": 600,
            "titleColor": "#555555",
            "titlePadding": 14,
            "labelFont": "Arial",
            "labelFontSize": 10,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        },
        "x2": {
          "field": "Smoking_Prevalence"
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#7a4e8f"
          },
          "value": "#d0d0d0"
        },
        "tooltip": [
          {
            "field": "Age_Group",
            "type": "ordinal",
            "title": "Age group"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 115,
        "stroke": "#ffffff",
        "strokeWidth": 1.4,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75 and above"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#7a4e8f"
          },
          "value": "#8f8f8f"
        },
        "tooltip": [
          {
            "field": "Age_Group",
            "type": "ordinal",
            "title": "Age group"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus === 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#7a4e8f",
        "align": "left",
        "baseline": "middle",
        "dx": 8
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75 and above"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus !== 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 10,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "middle",
        "dx": 8
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75 and above"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Age_Group": "35-44",
            "Smoking_Prevalence": 27.0,
            "Text": "Highest prevalence:\n25.0% among adults\naged 35–44."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 600,
        "color": "#5a3825",
        "align": "left",
        "baseline": "middle",
        "lineBreak": "\n",
        "lineHeight": 14,
        "limit": 150
      },
      "encoding": {
        "y": {
          "field": "Age_Group",
          "type": "ordinal",
          "sort": [
            "15-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65-74",
            "75 and above"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Text"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "legend": {
      "disable": true
    }
  }
}