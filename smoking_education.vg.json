{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {
    "left": 24,
    "right": 24,
    "top": 10,
    "bottom": 28
  },
  "title": {
    "text": "Smoking Is Higher Among Lower Education Groups",
    "subtitle": "Adults with primary education recorded the highest smoking prevalence in 2023.",
    "font": "Georgia",
    "fontSize": 30,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 16,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 15,
    "anchor": "start",
    "offset": 45
  },
  "width": 700,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_education.csv"
  },
  "transform": [
    {
      "calculate": "0",
      "as": "Zero"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Education_Level",
          "type": "ordinal",
          "title": null,
          "sort": [
            "No formal education",
            "Primary education",
            "Secondary education",
            "Tertiary education"
          ],
          "axis": {
            "labelFont": "Arial",
            "labelFontSize": 16,
            "labelColor": "#555555",
            "labelPadding": 10,
            "domain": false,
            "ticks": false
          }
        },
        "x": {
          "field": "Zero",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [0, 30],
            "nice": false
          },
          "axis": {
            "values": [0, 5, 10, 15, 20, 25, 30],
            "titleFont": "Arial",
            "titleFontSize": 16,
            "titleFontWeight": 600,
            "titleColor": "#555555",
            "titlePadding": 14,
            "labelFont": "Arial",
            "labelFontSize": 16,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        },
        "x2": {
          "field": "Smoking_Prevalence"
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#1DB954"
          },
          "value": "#D0D0D0"
        },
        "tooltip": [
          {
            "field": "Education_Level",
            "type": "ordinal",
            "title": "Education level"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 115,
        "stroke": "#ffffff",
        "strokeWidth": 1.4,
        "opacity": 1
      },
      "encoding": {
        "y": {
          "field": "Education_Level",
          "type": "ordinal",
          "sort": [
            "No formal education",
            "Primary education",
            "Secondary education",
            "Tertiary education"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#1DB954"
          },
          "value": "#8F8F8F"
        },
        "tooltip": [
          {
            "field": "Education_Level",
            "type": "ordinal",
            "title": "Education level"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus === 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 700,
        "color": "#129247",
        "align": "left",
        "baseline": "middle",
        "dx": 8
      },
      "encoding": {
        "y": {
          "field": "Education_Level",
          "type": "ordinal",
          "sort": [
            "No formal education",
            "Primary education",
            "Secondary education",
            "Tertiary education"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Focus !== 'Focus'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "middle",
        "dx": 8
      },
      "encoding": {
        "y": {
          "field": "Education_Level",
          "type": "ordinal",
          "sort": [
            "No formal education",
            "Primary education",
            "Secondary education",
            "Tertiary education"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Education_Level": "Primary education",
            "Smoking_Prevalence": 28.2,
            "Text": "Highest prevalence:\n25.4% among adults\nwith primary education."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 18,
        "fontWeight": 700,
        "color": "#1DB954",
        "align": "left",
        "baseline": "middle",
        "lineBreak": "\n",
        "lineHeight": 20,
        "limit": 300
      },
      "encoding": {
        "y": {
          "field": "Education_Level",
          "type": "ordinal",
          "sort": [
            "No formal education",
            "Primary education",
            "Secondary education",
            "Tertiary education"
          ]
        },
        "x": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [0, 30],
            "nice": false
          }
        },
        "text": {
          "field": "Text"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "legend": {
      "disable": true
    }
  }
}