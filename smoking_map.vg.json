{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "left": 20, "right": 20, "top": 4, "bottom": 8 },
  "title": {
    "text": "Smoking prevalence is highest in Sarawak",
    "subtitle": "Callouts mark selected high and low state rates.",
    "font": "Georgia",
    "fontSize": 37,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 20,
    "subtitleFontWeight": 400,
    "subtitlePadding": 15,
    "subtitleColor": "#666666",
    "anchor": "start",
    "offset": 45
  },
  "width": 1000,
  "height": 700,
  "projection": {
    "type": "mercator",
    "center": [108, 4.2],
    "scale": 2900
  },
  "layer": [
    {
      "data": { "sphere": true },
      "mark": { "type": "geoshape", "fill": "#edf5f8", "stroke": null }
    },
    {
      "data": { "graticule": { "step": [5, 5] } },
      "mark": { "type": "geoshape", "fill": null, "stroke": "#d5e2e7", "strokeWidth": 0.6, "opacity": 0.7 }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/malaysia-states.topojson",
        "format": { "type": "topojson", "feature": "states" }
      },
      "transform": [
        {
          "lookup": "properties.Name",
          "from": {
            "data": { "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_by_state.csv" },
            "key": "State",
            "fields": ["Smoking_Rate"]
          }
        }
      ],
      "mark": { "type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1.5 },
      "encoding": {
        "color": {
          "field": "Smoking_Rate",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [10, 30],
            "range": ["#fff7ec", "#fdd49e", "#fc8d59", "#d7301f", "#7f0000"]
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 330,
            "titleFont": "Arial",
            "titleFontSize": 15,
            "titleFontWeight": 700,
            "labelFont": "Arial",
            "labelFontSize": 14,
            "offset": 12
          }
        },
        "tooltip": [
          { "field": "properties.Name", "type": "nominal", "title": "State" },
          { "field": "Smoking_Rate", "type": "quantitative", "title": "Smoking prevalence (%)", "format": ".1f" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "state": "Sarawak",  "rate": "28.5%", "lon": 110.3,  "lat": 2.65 },
          { "state": "Sabah",    "rate": "24.9%", "lon": 114.25, "lat": 5.25 },
          { "state": "Perlis",   "rate": "26.4%", "lon": 100.25, "lat": 6.45 },
          { "state": "Selangor", "rate": "12.5%", "lon": 101.48, "lat": 3.25 }
        ]
      },
      "mark": { "type": "point", "filled": true, "size": 55, "color": "#3a302c", "opacity": 0.95 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "tooltip": [
          { "field": "state", "type": "nominal", "title": "Highlighted state" },
          { "field": "rate",  "type": "nominal", "title": "Smoking prevalence" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "lon": 110.3,  "lat": 2.65, "lon2": 114.6,  "lat2": 1.25 },
          { "lon": 114.25, "lat": 5.25, "lon2": 110.0,  "lat2": 5.85 },
          { "lon": 100.25, "lat": 6.45, "lon2": 100.0,  "lat2": 7.05 },
          { "lon": 101.48, "lat": 3.25, "lon2": 100.75, "lat2": 2.75 }
        ]
      },
      "mark": { "type": "rule", "stroke": "#4f4540", "strokeWidth": 1.3, "opacity": 0.85 },
      "encoding": {
        "longitude":  { "field": "lon",  "type": "quantitative" },
        "latitude":   { "field": "lat",  "type": "quantitative" },
        "longitude2": { "field": "lon2" },
        "latitude2":  { "field": "lat2" }
      }
    },
    {
      "data": {
        "values": [{ "label": "High northern rate\nPerlis, 26.4%", "lon": 99.0, "lat": 7.5 }]
      },
      "mark": {
        "type": "text", "font": "Arial", "fontSize": 15, "fontWeight": 700,
        "lineBreak": "\n", "lineHeight": 18,
        "baseline": "bottom", "align": "left", "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [{ "label": "Lowest state rate\nSelangor, 12.5%", "lon": 100.68, "lat": 2.72 }]
      },
      "mark": {
        "type": "text", "font": "Arial", "fontSize": 15, "fontWeight": 700,
        "lineBreak": "\n", "lineHeight": 18,
        "baseline": "middle", "align": "right", "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [{ "label": "Highest state rate\nSarawak, 28.5%", "lon": 114.65, "lat": 1.2 }]
      },
      "mark": {
        "type": "text", "font": "Arial", "fontSize": 15, "fontWeight": 700,
        "lineBreak": "\n", "lineHeight": 18,
        "baseline": "middle", "align": "left", "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [{ "label": "Above national rate\nSabah, 24.9%", "lon": 108.0, "lat": 6.5 }]
      },
      "mark": {
        "type": "text", "font": "Arial", "fontSize": 15, "fontWeight": 700,
        "lineBreak": "\n", "lineHeight": 18,
        "baseline": "middle", "align": "left", "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": { "stroke": null }
  }
}