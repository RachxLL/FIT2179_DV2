{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Interactive Malaysia state map showing current smoking prevalence in 2011 and 2023.",
  "width": 900,
  "height": 500,
  "background": "white",
  "title": {
    "text": "Smoking prevalence varies across Malaysian states",
    "subtitle": [
      "Use the year slider to compare current smoking prevalence in 2011 and 2023.",
      "Darker states show higher prevalence; Labuan has no separate 2011 estimate.",
      "Note: 2011 Sabah value includes Labuan in NHMS 2011 Table 2.26."
    ],
    "font": "Crimson Text",
    "fontSize": 30,
    "fontWeight": "bold",
    "color": "#3f2a1d",
    "subtitleFont": "Source Sans Pro",
    "subtitleFontSize": 16,
    "subtitleColor": "#4f5f66",
    "anchor": "start",
    "offset": 45,
    "subtitlePadding": 15
  },
  "params": [
    {
      "name": "selectedYear",
      "value": 2023
    }
  ],
  "data": {
    "url": "https://gist.githubusercontent.com/heiswayi/81a169ab39dcf749c31a/raw/malaysia.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "calculate": "indexof(datum.properties.name, 'Kuala') >= 0 ? 'Kuala Lumpur' : indexof(datum.properties.name, 'Putrajaya') >= 0 ? 'Putrajaya' : indexof(datum.properties.name, 'Labuan') >= 0 ? 'Labuan' : indexof(datum.properties.name, 'Sabah') >= 0 ? 'Sabah' : indexof(datum.properties.name, 'Sarawak') >= 0 ? 'Sarawak' : indexof(datum.properties.name, 'Pinang') >= 0 ? 'Penang' : indexof(datum.properties.name, 'Malacca') >= 0 ? 'Melaka' : datum.properties.name",
      "as": "StateKey"
    },
    {
      "lookup": "StateKey",
      "from": {
        "data": {
          "values": [
            {
              "State": "Johor",
              "Rate_2011": 19.9,
              "Rate_2023": 20.7
            },
            {
              "State": "Kedah",
              "Rate_2011": 21.7,
              "Rate_2023": 21.7
            },
            {
              "State": "Kelantan",
              "Rate_2011": 18.7,
              "Rate_2023": 21.4
            },
            {
              "State": "Melaka",
              "Rate_2011": 17.1,
              "Rate_2023": 17.8
            },
            {
              "State": "Negeri Sembilan",
              "Rate_2011": 19.4,
              "Rate_2023": 17.1
            },
            {
              "State": "Pahang",
              "Rate_2011": 20.6,
              "Rate_2023": 21.6
            },
            {
              "State": "Penang",
              "Rate_2011": 16.5,
              "Rate_2023": 15.2
            },
            {
              "State": "Perak",
              "Rate_2011": 16.1,
              "Rate_2023": 21.5
            },
            {
              "State": "Perlis",
              "Rate_2011": 22.6,
              "Rate_2023": 26.4
            },
            {
              "State": "Selangor",
              "Rate_2011": 18.8,
              "Rate_2023": 12.5
            },
            {
              "State": "Terengganu",
              "Rate_2011": 20.5,
              "Rate_2023": 17.9
            },
            {
              "State": "Sabah",
              "Rate_2011": 23.0,
              "Rate_2023": 24.9
            },
            {
              "State": "Labuan",
              "Rate_2011": null,
              "Rate_2023": 24.6
            },
            {
              "State": "Sarawak",
              "Rate_2011": 19.1,
              "Rate_2023": 28.5
            },
            {
              "State": "Kuala Lumpur",
              "Rate_2011": 17.4,
              "Rate_2023": 13.3
            },
            {
              "State": "Putrajaya",
              "Rate_2011": 15.6,
              "Rate_2023": 13.9
            }
          ]
        },
        "key": "State",
        "fields": [
          "Rate_2011",
          "Rate_2023"
        ]
      }
    },
    {
      "calculate": "datum['Rate_' + selectedYear]",
      "as": "Smoking_Rate"
    },
    {
      "calculate": "selectedYear == 2011 && datum.StateKey == 'Sabah' ? '2011 Sabah value includes Labuan.' : selectedYear == 2011 && datum.StateKey == 'Labuan' ? 'No separate 2011 estimate; included under Sabah.' : ''",
      "as": "Map_Note"
    },
    {
      "calculate": "isValid(datum.Smoking_Rate) ? format(datum.Smoking_Rate, '.1f') + '%' : 'Included under Sabah in 2011'",
      "as": "Smoking_Label"
    },
    {
      "calculate": "selectedYear == 2011 ? '2011' : '2023'",
      "as": "Selected_Year_Label"
    }
  ],
  "projection": {
    "type": "mercator"
  },
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1.2
  },
  "encoding": {
    "color": {
      "condition": {
        "test": "isValid(datum.Smoking_Rate)",
        "field": "Smoking_Rate",
        "type": "quantitative",
        "scale": {
          "domain": [
            12,
            30
          ],
          "range": [
            "#fff4dc",
            "#ffd08a",
            "#ff8c4a",
            "#ef3b2c",
            "#b30000"
          ]
        },
        "legend": {
          "title": "Current smoker (%)",
          "orient": "bottom",
          "direction": "horizontal",
          "gradientLength": 360,
          "gradientThickness": 14,
          "titleFont": "Source Sans Pro",
          "titleFontSize": 13,
          "titleColor": "#4f5f66",
          "labelFont": "Source Sans Pro",
          "labelFontSize": 12,
          "labelColor": "#4f5f66",
          "format": ".0f"
        }
      },
      "value": "#e6e6e6"
    },
    "tooltip": [
      {
        "field": "StateKey",
        "type": "nominal",
        "title": "State"
      },
      {
        "expr": "selectedYear",
        "type": "quantitative",
        "title": "Year",
        "format": "d"
      },
      {
        "field": "Smoking_Label",
        "type": "nominal",
        "title": "Current smoking prevalence"
      },
      {
        "field": "Map_Note",
        "type": "nominal",
        "title": "Note"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Source Sans Pro"
  }
}