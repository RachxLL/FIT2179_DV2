{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "left": 20, "right": 20, "top": 4, "bottom": 8 },
  "title": {
    "text": "Smoking prevalence varies across Malaysian states",
    "subtitle": [
      "Use the year slider to compare current smoking prevalence in 2011 and 2023.",
      "Darker states show higher smoking prevalence.",
      "Note: 2011 Sabah value includes Labuan."
    ],
    "font": "Georgia",
    "fontSize": 37,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 20,
    "subtitleFontWeight": 400,
    "subtitlePadding": 15,
    "subtitleColor": "#666666",
    "anchor": "start",
    "offset": 45
  },
  "width": 1000,
  "height": 600,
  "params": [
    {
      "name": "selectedYear",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2011,
        "max": 2023,
        "step": 12,
        "name": "Year: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [108, 4.2],
    "scale": 2900
  },
  "layer": [
    {
      "data": { "sphere": true },
      "mark": {
        "type": "geoshape",
        "fill": "#edf5f8",
        "stroke": null
      }
    },
    {
      "data": { "graticule": { "step": [5, 5] } },
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#d5e2e7",
        "strokeWidth": 0.6,
        "opacity": 0.7
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/malaysia-states.topojson",
        "format": { "type": "topojson", "feature": "states" }
      },
      "transform": [
        {
          "lookup": "properties.Name",
          "from": {
            "data": {
              "values": [
                { "State": "Johor",           "Rate_2011": 19.9, "Rate_2023": 20.7 },
                { "State": "Kedah",           "Rate_2011": 21.7, "Rate_2023": 21.7 },
                { "State": "Kelantan",        "Rate_2011": 18.7, "Rate_2023": 21.4 },
                { "State": "Melaka",          "Rate_2011": 17.1, "Rate_2023": 17.8 },
                { "State": "Negeri Sembilan", "Rate_2011": 19.4, "Rate_2023": 17.1 },
                { "State": "Pahang",          "Rate_2011": 20.6, "Rate_2023": 21.6 },
                { "State": "Penang",          "Rate_2011": 16.5, "Rate_2023": 15.2 },
                { "State": "Perak",           "Rate_2011": 16.1, "Rate_2023": 21.5 },
                { "State": "Perlis",          "Rate_2011": 22.6, "Rate_2023": 26.4 },
                { "State": "Selangor",        "Rate_2011": 18.8, "Rate_2023": 12.5 },
                { "State": "Terengganu",      "Rate_2011": 20.5, "Rate_2023": 17.9 },
                { "State": "Sabah",           "Rate_2011": 23.0, "Rate_2023": 24.9 },
                { "State": "Labuan",          "Rate_2011": null, "Rate_2023": 24.6 },
                { "State": "Sarawak",         "Rate_2011": 19.1, "Rate_2023": 28.5 },
                { "State": "Kuala Lumpur",    "Rate_2011": 17.4, "Rate_2023": 13.3 },
                { "State": "Putrajaya",       "Rate_2011": 15.6, "Rate_2023": 13.9 }
              ]
            },
            "key": "State",
            "fields": ["Rate_2011", "Rate_2023"]
          }
        },
        {
          "calculate": "datum['Rate_' + selectedYear]",
          "as": "Smoking_Rate"
        },
        {
          "calculate": "isValid(datum.Smoking_Rate) ? format(datum.Smoking_Rate, '.1f') + '%' : 'Included under Sabah in 2011'",
          "as": "Smoking_Label"
        },
        {
          "calculate": "selectedYear == 2011 && datum.properties.Name == 'Labuan' ? 'No separate 2011 estimate; included under Sabah.' : selectedYear == 2011 && datum.properties.Name == 'Sabah' ? '2011 Sabah value includes Labuan.' : ''",
          "as": "Map_Note"
        },
        {
          "calculate": "selectedYear",
          "as": "Year"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "color": {
          "condition": {
            "test": "isValid(datum.Smoking_Rate)",
            "field": "Smoking_Rate",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "scale": {
              "domain": [10, 30],
              "range": ["#fff7ec", "#fdd49e", "#fc8d59", "#d7301f", "#7f0000"]
            },
            "legend": {
              "orient": "bottom",
              "direction": "horizontal",
              "gradientLength": 330,
              "gradientThickness": 14,
              "titleFont": "Arial",
              "titleFontSize": 15,
              "titleFontWeight": 700,
              "labelFont": "Arial",
              "labelFontSize": 14,
              "offset": 12
            }
          },
          "value": "#e6e6e6"
        },
        "tooltip": [
          {
            "field": "properties.Name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Smoking_Label",
            "type": "nominal",
            "title": "Smoking prevalence"
          },
          {
            "field": "Map_Note",
            "type": "nominal",
            "title": "Note"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "state": "Sarawak",  "lon": 110.3,  "lat": 2.65, "rate_2011": 19.1, "rate_2023": 28.5 },
          { "state": "Sabah",    "lon": 114.25, "lat": 5.25, "rate_2011": 23.0, "rate_2023": 24.9 },
          { "state": "Perlis",   "lon": 100.25, "lat": 6.45, "rate_2011": 22.6, "rate_2023": 26.4 },
          { "state": "Selangor", "lon": 101.48, "lat": 3.25, "rate_2011": 18.8, "rate_2023": 12.5 }
        ]
      },
      "transform": [
        {
          "calculate": "selectedYear == 2011 ? format(datum.rate_2011, '.1f') + '%' : format(datum.rate_2023, '.1f') + '%'",
          "as": "Dot_Rate"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 55,
        "color": "#3a302c",
        "opacity": 0.95
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "Highlighted state"
          },
          {
            "field": "Dot_Rate",
            "type": "nominal",
            "title": "Smoking prevalence"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "lon": 110.3,  "lat": 2.65, "lon2": 114.6, "lat2": 1.25 },
          { "lon": 114.25, "lat": 5.25, "lon2": 110.0, "lat2": 5.85 },
          { "lon": 100.25, "lat": 6.45, "lon2": 100.0, "lat2": 7.05 },
          { "lon": 101.48, "lat": 3.25, "lon2": 100.75,"lat2": 2.75 }
        ]
      },
      "mark": {
        "type": "rule",
        "stroke": "#4f4540",
        "strokeWidth": 1.3,
        "opacity": 0.85
      },
      "encoding": {
        "longitude":  { "field": "lon",  "type": "quantitative" },
        "latitude":   { "field": "lat",  "type": "quantitative" },
        "longitude2": { "field": "lon2" },
        "latitude2":  { "field": "lat2" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label_2011": "High northern rate\nPerlis, 22.6%",
            "label_2023": "High northern rate\nPerlis, 26.4%",
            "lon": 99.0, "lat": 7.5
          }
        ]
      },
      "transform": [
        {
          "calculate": "selectedYear == 2011 ? datum.label_2011 : datum.label_2023",
          "as": "label"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 15,
        "fontWeight": 700,
        "lineBreak": "\n",
        "lineHeight": 18,
        "baseline": "bottom",
        "align": "left",
        "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label_2011": "Lower central rate\nSelangor, 18.8%",
            "label_2023": "Lowest state rate\nSelangor, 12.5%",
            "lon": 100.98, "lat": 2.5
          }
        ]
      },
      "transform": [
        {
          "calculate": "selectedYear == 2011 ? datum.label_2011 : datum.label_2023",
          "as": "label"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 15,
        "fontWeight": 700,
        "lineBreak": "\n",
        "lineHeight": 18,
        "baseline": "middle",
        "align": "right",
        "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label_2011": "East Malaysia rate\nSarawak, 19.1%",
            "label_2023": "Highest state rate\nSarawak, 28.5%",
            "lon": 114.65, "lat": 1.2
          }
        ]
      },
      "transform": [
        {
          "calculate": "selectedYear == 2011 ? datum.label_2011 : datum.label_2023",
          "as": "label"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 15,
        "fontWeight": 700,
        "lineBreak": "\n",
        "lineHeight": 18,
        "baseline": "middle",
        "align": "left",
        "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label_2011": "2011 value includes Labuan\nSabah, 23.0%",
            "label_2023": "Above national rate\nSabah, 24.9%",
            "lon": 108.0, "lat": 6.5
          }
        ]
      },
      "transform": [
        {
          "calculate": "selectedYear == 2011 ? datum.label_2011 : datum.label_2023",
          "as": "label"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 15,
        "fontWeight": 700,
        "lineBreak": "\n",
        "lineHeight": 18,
        "baseline": "middle",
        "align": "left",
        "color": "#3a302c"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "text":      { "field": "label" }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": { "stroke": null },
    "font": "Arial"
  }
}