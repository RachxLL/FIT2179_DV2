{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {
    "left": 28,
    "right": 36,
    "top": 8,
    "bottom": 20
  },
  "title": {
    "text": "Smoking prevalence has declined over time",
    "subtitle": "2011 is the key comparison point; 2023 is the latest data.",
    "font": "Georgia",
    "fontSize": 22,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 12,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "anchor": "start",
    "offset": 6
  },
  "width": 840,
  "height": 380,
  "data": {
    "url": "smoking_timeseries.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3.5,
        "color": "#2f6f73",
        "opacity": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "title": null,
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          },
          "axis": {
            "values": [
              2003, 2004, 2005, 2006, 2007, 2008, 2009, 2010,
              2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018,
              2019, 2020, 2021, 2022, 2023
            ],
            "format": "d",
            "labelFont": "Arial",
            "labelFontSize": 9,
            "labelFontWeight": {
              "expr": "datum.value == 2011 || datum.value == 2023 ? 700 : 400"
            },
            "labelColor": {
              "expr": "datum.value == 2011 || datum.value == 2023 ? '#5a3825' : '#9a9a9a'"
            },
            "labelAngle": 0,
            "labelPadding": 8,
            "domain": false,
            "ticks": false,
            "grid": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [15, 30]
          },
          "axis": {
            "titleFont": "Arial",
            "titleFontSize": 11,
            "titleFontWeight": 600,
            "titleColor": "#555555",
            "titlePadding": 18,
            "labelFont": "Arial",
            "labelFontSize": 10,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 74,
        "stroke": "#ffffff",
        "strokeWidth": 1.4,
        "opacity": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "color": {
          "condition": {
            "test": "datum.Focus === 'Focus'",
            "value": "#5a3825"
          },
          "value": "#2f6f73"
        },
        "tooltip": [
          {
            "field": "Year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Year === 2011 || datum.Year === 2023"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#5a3825",
        "align": "center",
        "baseline": "bottom",
        "dy": -10
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "text": {
          "field": "Label"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2004.8,
            "Smoking_Prevalence": 29.0,
            "Text": "Rates were above 26% before 2011."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "top",
        "limit": 230
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "text": {
          "field": "Text"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2009.7,
            "Smoking_Prevalence": 24.9,
            "Text": "2011 serves as the main comparison year."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 600,
        "color": "#5a3825",
        "align": "right",
        "baseline": "middle",
        "limit": 240
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "text": {
          "field": "Text"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2014.0,
            "Smoking_Prevalence": 16.1,
            "Text": "Later survey years provide additional trend context."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 10,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "middle",
        "limit": 280
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "text": {
          "field": "Text"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": 2022.6,
            "Smoking_Prevalence": 17.3,
            "Text": "By 2023, prevalence fell to 19.0%."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": 600,
        "color": "#5a3825",
        "align": "right",
        "baseline": "top",
        "limit": 220
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {
            "domain": [2003, 2023],
            "nice": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [15, 30]
          }
        },
        "text": {
          "field": "Text"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "legend": {
      "disable": true
    }
  }
}