{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": { "left": 32, "right": 32, "top": 8, "bottom": 28 },
  "title": {
    "text": "Smoking prevalence has declined over time",
    "subtitle": "2011 is the key comparison point; 2023 is the latest data.",
    "font": "Georgia",
    "fontSize": 30,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 16,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 15,
    "anchor": "start",
    "offset": 45
  },
  "width": 700,
  "height": 550,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_timeseries.csv"
  },
  "layer": [
    {
      "mark": { "type": "line", "strokeWidth": 4, "color": "#66d9ff", "opacity": 1 },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "title": null,
          "scale": { "domain": [2003, 2023], "nice": false },
          "axis": {
            "values": [2003,2004,2005,2006,2007,2008,2009,2010,2011,2012,2013,2014,2015,2016,2017,2018,2019,2020,2021,2022,2023],
            "format": "d",
            "labelFont": "Arial",
            "labelFontSize": 14,
            "labelFontWeight": { "expr": "datum.value == 2011 || datum.value == 2023 ? 700 : 400" },
            "labelColor": { "expr": "datum.value == 2011 || datum.value == 2023 ? '#5a3825' : '#8a8a8a'" },
            "labelAngle": 0,
            "labelPadding": 10,
            "domain": false,
            "ticks": false,
            "grid": false
          }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": { "domain": [15, 30] },
          "axis": {
            "titleFont": "Arial",
            "titleFontSize": 15,
            "titleFontWeight": 700,
            "titleColor": "#555555",
            "titlePadding": 22,
            "labelFont": "Arial",
            "labelFontSize": 14,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 95,
        "stroke": "#ffffff",
        "strokeWidth": 1.6,
        "opacity": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": { "domain": [2003, 2023], "nice": false }
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": { "domain": [15, 30] }
        },
        "color": {
          "condition": { "test": "datum.Focus === 'Focus'", "value": "#5a3825" },
          "value": "#66d9ff"
        },
        "tooltip": [
          { "field": "Year", "type": "quantitative", "title": "Year", "format": "d" },
          { "field": "Smoking_Prevalence", "type": "quantitative", "title": "Smoking prevalence (%)", "format": ".1f" }
        ]
      }
    },
    {
      "data": { "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_timeseries.csv" },
      "transform": [{ "filter": "datum.Year === 2011" }],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 700,
        "color": "#5a3825",
        "align": "left",
        "baseline": "bottom",
        "dx": 12,
        "dy": -14
      },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "scale": { "domain": [2003, 2023], "nice": false } },
        "y": { "field": "Smoking_Prevalence", "type": "quantitative", "scale": { "domain": [15, 30] } },
        "text": { "field": "Label" }
      }
    },
    {
      "data": { "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_timeseries.csv" },
      "transform": [{ "filter": "datum.Year === 2023" }],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 16,
        "fontWeight": 700,
        "color": "#5a3825",
        "align": "right",
        "baseline": "bottom",
        "dx": -16,
        "dy": -14
      },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "scale": { "domain": [2003, 2023], "nice": false } },
        "y": { "field": "Smoking_Prevalence", "type": "quantitative", "scale": { "domain": [15, 30] } },
        "text": { "field": "Label" }
      }
    },
    {
      "data": {
        "values": [{ "Year": 2005.0, "Smoking_Prevalence": 29.0, "Text": "Before 2011, measured rates were above 26%." }]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": 400,
        "color": "#666666",
        "align": "left",
        "baseline": "top",
        "limit": 380
      },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "scale": { "domain": [2003, 2023], "nice": false } },
        "y": { "field": "Smoking_Prevalence", "type": "quantitative", "scale": { "domain": [15, 30] } },
        "text": { "field": "Text" }
      }
    },
    {
      "data": {
        "values": [{ "Year": 2007.6, "Smoking_Prevalence": 21.4, "Text": "2011 is the main comparison year." }]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": 700,
        "color": "#5a3825",
        "align": "left",
        "baseline": "middle",
        "limit": 340
      },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "scale": { "domain": [2003, 2023], "nice": false } },
        "y": { "field": "Smoking_Prevalence", "type": "quantitative", "scale": { "domain": [15, 30] } },
        "text": { "field": "Text" }
      }
    },
    {
      "data": {
        "values": [{ "Year": 2021.8, "Smoking_Prevalence": 18.35, "Text": "Latest available data." }]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": 700,
        "color": "#5a3825",
        "align": "right",
        "baseline": "middle",
        "limit": 300
      },
      "encoding": {
        "x": { "field": "Year", "type": "quantitative", "scale": { "domain": [2003, 2023], "nice": false } },
        "y": { "field": "Smoking_Prevalence", "type": "quantitative", "scale": { "domain": [15, 30] } },
        "text": { "field": "Text" }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": { "stroke": null },
    "legend": { "disable": true }
  }
}