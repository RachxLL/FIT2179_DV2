{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "padding": {
    "left": 42,
    "right": 42,
    "top": 10,
    "bottom": 30
  },
  "title": {
    "text": "Men Still Smoke at Much Higher Rates",
    "subtitle": "Smoking prevalence remained far higher among men in both 2011 and 2023.",
    "font": "Georgia",
    "fontSize": 30,
    "fontWeight": 700,
    "color": "#5a3825",
    "subtitleFont": "Arial",
    "subtitleFontSize": 16,
    "subtitleFontWeight": 400,
    "subtitleColor": "#666666",
    "subtitlePadding": 15,
    "anchor": "start",
    "offset": 45
  },
  "width": 700,
  "height": 600,
  "data": {
    "url": "https://raw.githubusercontent.com/RachxLL/FIT2179_DV2/main/smoking_gender.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4,
        "opacity": 1,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": null,
          "sort": [
            "2011",
            "2023"
          ],
          "axis": {
            "labelFont": "Arial",
            "labelFontSize": 25,
            "labelFontWeight": 600,
            "labelColor": "#5a3825",
            "domain": false,
            "ticks": false,
            "labelPadding": 14
          }
        },
        "xOffset": {
          "field": "Gender",
          "type": "nominal",
          "sort": [
            "Men",
            "Women"
          ]
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "title": "Smoking prevalence (%)",
          "scale": {
            "domain": [
              0,
              50
            ],
            "nice": false
          },
          "axis": {
            "values": [
              0,
              10,
              20,
              30,
              40,
              50
            ],
            "titleFont": "Arial",
            "titleFontSize": 18,
            "titleFontWeight": 700,
            "titleColor": "#555555",
            "titlePadding": 18,
            "labelFont": "Arial",
            "labelFontSize": 25,
            "labelColor": "#666666",
            "grid": true,
            "gridColor": "#eeeeee",
            "domain": false,
            "ticks": false
          }
        },
        "color": {
          "field": "Gender",
          "type": "nominal",
          "scale": {
            "domain": [
              "Men",
              "Women"
            ],
            "range": [
              "#c66a1f",
              "#f3d98b"
            ]
          },
          "legend": {
            "title": null,
            "orient": "top-right",
            "direction": "horizontal",
            "labelFont": "Arial",
            "labelFontSize": 25,
            "labelColor": "#555555",
            "symbolType": "square",
            "symbolSize": 160,
            "offset": 10
          }
        },
        "tooltip": [
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Gender",
            "type": "nominal",
            "title": "Gender"
          },
          {
            "field": "Smoking_Prevalence",
            "type": "quantitative",
            "title": "Smoking prevalence (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 17,
        "fontWeight": 700,
        "baseline": "bottom",
        "dy": -8
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "sort": [
            "2011",
            "2023"
          ]
        },
        "xOffset": {
          "field": "Gender",
          "type": "nominal",
          "sort": [
            "Men",
            "Women"
          ]
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              50
            ],
            "nice": false
          }
        },
        "text": {
          "field": "Label"
        },
        "color": {
          "condition": {
            "test": "datum.Gender === 'Men'",
            "value": "#9a4a12"
          },
          "value": "#8a6a19"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "Year": "2023",
            "Smoking_Prevalence": 42.0,
            "Text": "Male smoking declined, but the\ngender gap remained very large."
          }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 18,
        "fontWeight": 600,
        "color": "#5a3825",
        "align": "center",
        "baseline": "middle",
        "limit": 1000,
        "lineBreak": "\n",
        "lineHeight": 20
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "sort": [
            "2011",
            "2023"
          ]
        },
        "y": {
          "field": "Smoking_Prevalence",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              50
            ],
            "nice": false
          }
        },
        "text": {
          "field": "Text"
        }
      }
    }
  ],
  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    },
    "bar": {
      "discreteBandSize": 42
    }
  }
}